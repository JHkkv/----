<!--pages/index/index.wxml-->
<view class="container">
  <view class="header">
    <view class="logo">🎵</view>
    <view class="title">声乐练习</view>
    <view class="subtitle">课后练习反馈平台</view>
  </view>

  <!-- No role yet -->
  <view class="card" wx:if="{{!hasRole}}">
    <view class="label">请选择你的身份</view>
    <button class="btn-primary" bindtap="showTeacherModal" style="margin-bottom:20rpx">我是老师</button>
    <button class="btn-outline" bindtap="showStudentModal">我是学生</button>
  </view>

  <!-- Student Home -->
  <view wx:if="{{role === 'student'}}">
    <view class="card">
      <view class="role-badge student">学生</view>
      <view class="welcome">你好，{{nickName}}</view>
      <view class="info" wx:if="{{teacherName}}">老师：{{teacherName}}</view>
    </view>
    <view class="card menu-card" bindtap="goAssignments">
      <view class="menu-icon">📋</view>
      <view class="menu-text">
        <view class="menu-title">我的作业</view>
        <view class="menu-desc">查看老师布置的练习任务</view>
      </view>
      <view class="menu-arrow">›</view>
    </view>
    <view class="card menu-card" bindtap="goPractice">
      <view class="menu-icon">🎙️</view>
      <view class="menu-text">
        <view class="menu-title">开始练习</view>
        <view class="menu-desc">录音并提交练习给老师</view>
      </view>
      <view class="menu-arrow">›</view>
    </view>
    <view class="card menu-card" bindtap="goHistory">
      <view class="menu-icon">📝</view>
      <view class="menu-text">
        <view class="menu-title">练习记录</view>
        <view class="menu-desc">查看过往提交和老师反馈</view>
      </view>
      <view class="menu-arrow">›</view>
    </view>
  </view>

  <!-- Teacher Home -->
  <view wx:if="{{role === 'teacher'}}">
    <view class="card">
      <view class="role-badge teacher">老师</view>
      <view class="welcome">你好，{{nickName}}</view>
      <view class="invite-box">
        <view class="info">邀请码（分享给学生）</view>
        <view class="invite-code">{{inviteCode}}</view>
      </view>
    </view>
    <view class="card menu-card" bindtap="goCreateAssignment">
      <view class="menu-icon">✍️</view>
      <view class="menu-text">
        <view class="menu-title">布置作业</view>
        <view class="menu-desc">给学生布置练习任务</view>
      </view>
      <view class="menu-arrow">›</view>
    </view>
    <view class="card menu-card" bindtap="goSubmissions">
      <view class="menu-icon">🎧</view>
      <view class="menu-text">
        <view class="menu-title">学生提交</view>
        <view class="menu-desc">查看和点评学生的练习录音</view>
      </view>
      <view class="menu-arrow">›</view>
    </view>
    <view class="card menu-card" bindtap="goStudents">
      <view class="menu-icon">👥</view>
      <view class="menu-text">
        <view class="menu-title">学生管理</view>
        <view class="menu-desc">查看已绑定的学生列表</view>
      </view>
      <view class="menu-arrow">›</view>
    </view>
  </view>

  <!-- Teacher register modal -->
  <view class="modal" wx:if="{{showTeacherModal}}">
    <view class="modal-mask" bindtap="hideModals"></view>
    <view class="modal-content">
      <view class="modal-title">注册为老师</view>
      <input class="input-field" placeholder="请输入你的称呼" value="{{teacherNameInput}}" bindinput="onTeacherNameInput" />
      <button class="btn-primary" bindtap="registerTeacher">确认注册</button>
      <button class="btn-outline" style="margin-top:16rpx" bindtap="hideModals">取消</button>
    </view>
  </view>

  <!-- Student register modal -->
  <view class="modal" wx:if="{{showStudentModal}}">
    <view class="modal-mask" bindtap="hideModals"></view>
    <view class="modal-content">
      <view class="modal-title">绑定老师</view>
      <input class="input-field" placeholder="请输入你的称呼" value="{{studentNameInput}}" bindinput="onStudentNameInput" />
      <input class="input-field" placeholder="请输入老师提供的邀请码" value="{{inviteInput}}" bindinput="onInviteInput" />
      <button class="btn-primary" bindtap="registerStudent">确认绑定</button>
      <button class="btn-outline" style="margin-top:16rpx" bindtap="hideModals">取消</button>
    </view>
  </view>
</view>
