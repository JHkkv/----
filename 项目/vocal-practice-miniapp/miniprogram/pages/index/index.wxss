.header {
  text-align: center;
  padding: 60rpx 0 40rpx;
}
.logo { font-size: 80rpx; margin-bottom: 16rpx; }
.title { font-size: 44rpx; font-weight: 700; color: var(--primary); margin-bottom: 8rpx; }
.subtitle { font-size: 26rpx; color: var(--text-light); }

.role-badge {
  display: inline-block;
  padding: 6rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-bottom: 12rpx;
}
.role-badge.student { background: #e6f7ff; color: #1890ff; }
.role-badge.teacher { background: #fff7e6; color: #fa8c16; }

.welcome { font-size: 36rpx; font-weight: 600; margin-bottom: 8rpx; }
.info { color: var(--text-light); font-size: 26rpx; margin-top: 4rpx; }

.invite-box {
  margin-top: 16rpx;
  padding: 16rpx 0;
}
.invite-code {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--primary);
  letter-spacing: 6rpx;
  margin-top: 8rpx;
}

.menu-card {
  display: flex;
  align-items: center;
  padding: 32rpx 24rpx;
}
.menu-icon { font-size: 48rpx; margin-right: 24rpx; }
.menu-text { flex: 1; }
.menu-title { font-size: 30rpx; font-weight: 600; margin-bottom: 4rpx; }
.menu-desc { font-size: 24rpx; color: var(--text-light); }
.menu-arrow { font-size: 40rpx; color: #ccc; }

.modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 100;
}
.modal-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
}
.modal-content {
  position: absolute;
  left: 40rpx; right: 40rpx; bottom: 100rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
}
.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 30rpx;
  text-align: center;
}
