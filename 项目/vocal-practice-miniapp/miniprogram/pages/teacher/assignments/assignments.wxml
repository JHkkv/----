<!--pages/teacher/assignments/assignments.wxml-->
<view class="container">
  <view class="page-title">布置作业</view>

  <!-- Create form -->
  <view class="card">
    <view class="label">作业标题</view>
    <input class="input-field" placeholder="如：练习《送别》前两段" value="{{title}}" bindinput="onTitle" />

    <view class="label">曲目名称</view>
    <input class="input-field" placeholder="请输入曲目名称" value="{{trackName}}" bindinput="onTrack" />

    <view class="label">作业说明</view>
    <textarea class="textarea-field" placeholder="具体的练习要求和注意事项..." value="{{description}}" bindinput="onDesc" />

    <view class="label">截止日期（可选）</view>
    <picker mode="date" value="{{deadline}}" bindchange="onDeadline">
      <view class="input-field">{{deadline || '点击选择截止日期'}}</view>
    </picker>

    <button class="btn-primary" bindtap="create" disabled="{{creating}}">
      {{creating ? '发布中...' : '发布作业'}}
    </button>
  </view>

  <!-- Existing assignments -->
  <view class="page-title" style="margin-top:40rpx">已发布的作业</view>
  <view class="card" wx:for="{{list}}" wx:key="_id">
    <view class="assign-title">{{item.title}}</view>
    <view class="assign-meta" wx:if="{{item.trackName}}">曲目：{{item.trackName}}</view>
    <view class="assign-desc" wx:if="{{item.description}}">{{item.description}}</view>
    <view class="assign-footer">
      <view>{{item.createTimeText}}</view>
      <view class="assign-deadline" wx:if="{{item.deadline}}">截止：{{item.deadline}}</view>
    </view>
  </view>
  <view class="empty-state" wx:if="{{list.length === 0}}">
    <view class="icon">📋</view>
    <view>暂无已发布作业</view>
  </view>
</view>
