.page-title { font-size: 36rpx; font-weight: 700; margin-bottom: 24rpx; }
.sub-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 6rpx; }
.sub-student { font-size: 30rpx; font-weight: 600; color: var(--primary); }
.sub-time { font-size: 24rpx; color: var(--text-light); }
.sub-track { font-size: 26rpx; margin-bottom: 4rpx; }
.sub-duration { font-size: 24rpx; color: var(--text-light); margin-bottom: 12rpx; }
.sub-label { font-size: 26rpx; font-weight: 600; margin-bottom: 4rpx; }
.sub-review { margin-top: 16rpx; padding: 16rpx 0; border-top: 1rpx solid var(--border); font-size: 26rpx; }
.existing-feedback { margin-top: 16rpx; padding: 16rpx; background: #f6ffed; border-radius: 12rpx; }
.feedback-text { font-size: 26rpx; color: #389e0d; }
.feedback-area { margin-top: 20rpx; padding: 16rpx 0; border-top: 1rpx solid var(--border); }
.btn-small { margin-top: 12rpx; width: 200rpx; font-size: 26rpx; }
