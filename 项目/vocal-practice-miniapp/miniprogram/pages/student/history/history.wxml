<!--pages/student/history/history.wxml-->
<view class="container">
  <view class="page-title">练习记录</view>

  <view class="empty-state" wx:if="{{list.length === 0 && !loading}}">
    <view class="icon">📝</view>
    <view>暂无练习记录</view>
    <button class="btn-primary" style="margin-top:24rpx;width:300rpx" bindtap="goPractice">开始练习</button>
  </view>

  <view wx:for="{{list}}" wx:key="_id" class="card">
    <view class="sub-header">
      <view class="sub-track">{{item.trackName || '未指定曲目'}}</view>
      <view class="sub-time">{{item.submitTimeText}}</view>
    </view>
    <view class="sub-duration">录音时长：{{item.audioDuration}}秒</view>
    <audio-player src="{{item.audioUrl}}" label="练习录音" wx:if="{{item.audioUrl}}" />
    <view class="sub-review" wx:if="{{item.selfReview}}">
      <view class="sub-label">自我评价：</view>
      <view>{{item.selfReview}}</view>
    </view>
    <view class="sub-feedback" wx:if="{{item.teacherFeedback}}">
      <view class="sub-label">老师点评：</view>
      <view class="feedback-text">{{item.teacherFeedback}}</view>
    </view>
    <view class="no-feedback" wx:if="{{!item.teacherFeedback}}">等待老师点评...</view>
  </view>
</view>
