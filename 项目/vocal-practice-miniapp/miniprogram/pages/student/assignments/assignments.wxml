<!--pages/student/assignments/assignments.wxml-->
<view class="container">
  <view class="page-title">我的作业</view>

  <view class="empty-state" wx:if="{{list.length === 0 && !loading}}">
    <view class="icon">📋</view>
    <view>暂未收到作业</view>
    <view style="font-size:24rpx;margin-top:8rpx">等待老师布置练习任务</view>
  </view>

  <view wx:for="{{list}}" wx:key="_id" class="card">
    <view class="assign-title">{{item.title}}</view>
    <view class="assign-meta" wx:if="{{item.trackName}}">曲目：{{item.trackName}}</view>
    <view class="assign-desc" wx:if="{{item.description}}">{{item.description}}</view>
    <view class="assign-footer">
      <view class="assign-time">{{item.createTimeText}}</view>
      <view class="assign-deadline" wx:if="{{item.deadline}}">截止：{{item.deadline}}</view>
    </view>
    <button class="btn-primary" style="margin-top:16rpx" bindtap="goPractice" data-id="{{item._id}}">去练习</button>
  </view>
</view>
