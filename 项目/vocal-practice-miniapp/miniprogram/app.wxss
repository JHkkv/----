page {
  --primary: #4A90D9;
  --primary-dark: #357ABD;
  --bg: #f5f5f5;
  --card: #ffffff;
  --text: #333333;
  --text-light: #888888;
  --border: #e8e8e8;
  --success: #52c41a;
  --warn: #faad14;

  background: var(--bg);
  font-size: 28rpx;
  color: var(--text);
  min-height: 100vh;
}

.container {
  padding: 24rpx;
}

.card {
  background: var(--card);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.btn-primary {
  background: var(--primary);
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  padding: 20rpx 0;
}

.btn-primary:active {
  background: var(--primary-dark);
}

.btn-outline {
  background: #fff;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: 12rpx;
  font-size: 30rpx;
  padding: 20rpx 0;
}

.input-field {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

.textarea-field {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  min-height: 150rpx;
}

.label {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  color: var(--text);
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
  color: var(--text-light);
}

.empty-state .icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}
