<!--components/audio-player/audio-player.wxml-->
<view class="player" wx:if="{{src}}">
  <view class="player-control {{playing ? 'playing' : ''}}" bindtap="togglePlay">
    <text>{{playing ? '⏸' : '▶'}}</text>
  </view>
  <view class="player-info">
    <view class="player-label">{{label}}</view>
    <view class="player-duration">{{currentText}} / {{durationText}}</view>
    <progress percent="{{progress}}" stroke-width="4" activeColor="#4A90D9" backgroundColor="#e8e8e8" />
  </view>
</view>
