.recorder { text-align: center; padding: 24rpx 0; }
.record-time { font-size: 64rpx; font-weight: 300; margin-bottom: 16rpx; font-variant-numeric: tabular-nums; }
.record-status { font-size: 26rpx; color: #e74c3c; margin-bottom: 32rpx; display: flex; align-items: center; justify-content: center; gap: 12rpx; }
.record-status.done { color: var(--success); }

.pulse-dot {
  width: 16rpx; height: 16rpx;
  background: #e74c3c; border-radius: 50%;
  animation: pulse 1s infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.3; transform: scale(1.5); }
}

.record-actions { margin-top: 20rpx; }
.btn-record { background: #fff; border: 2rpx solid #e74c3c; border-radius: 24rpx; padding: 32rpx; color: #e74c3c; font-size: 28rpx; }
.btn-record.stop { border-color: var(--primary); color: var(--primary); }
.btn-record-icon { font-size: 56rpx; margin-bottom: 8rpx; }

.preview-controls { display: flex; gap: 20rpx; justify-content: center; }
.btn-small { font-size: 26rpx; padding: 16rpx 32rpx; border-radius: 12rpx; background: var(--primary); color: #fff; border: none; }
.btn-small.stop { background: #e74c3c; }

.upload-bar { margin-top: 24rpx; }
.upload-bar text { font-size: 24rpx; color: var(--text-light); margin-top: 8rpx; display: block; }
