.page-title { font-size: 36rpx; font-weight: 700; margin-bottom: 24rpx; }
.invite-card { text-align: center; padding: 40rpx 24rpx; }
.invite-label { font-size: 28rpx; color: var(--text-light); margin-bottom: 8rpx; }
.invite-code {
  font-size: 56rpx; font-weight: 700; color: var(--primary);
  letter-spacing: 10rpx; margin-bottom: 12rpx;
}
.invite-tip { font-size: 24rpx; color: var(--text-light); }

.student-card { display: flex; align-items: center; gap: 20rpx; }
.student-avatar {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: var(--primary);
  color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; font-weight: 600;
  flex-shrink: 0;
}
.student-info { flex: 1; }
.student-name { font-size: 30rpx; font-weight: 600; margin-bottom: 4rpx; }
.student-time { font-size: 24rpx; color: var(--text-light); }
